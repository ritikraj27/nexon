# ============================================================
# NEXON .env — Place this file at: /Users/ritikraj/Desktop/nexon/.env
# Fill in the values you have. Leave others blank — those
# features run in demo mode without crashing anything.
# ============================================================

# ── LLM ─────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
LLM_PROVIDER=ollama

# Optional: Groq for faster/smarter responses (free at console.groq.com)
GROQ_API_KEY=
GROQ_MODEL=llama3-70b-8192

# ── Speech ───────────────────────────────────────────────────
# tiny=fastest, base=good balance, small=accurate, medium=best
WHISPER_MODEL=tiny
TTS_RATE=175
TTS_VOLUME=1.0

# ── Database ─────────────────────────────────────────────────
DB_PATH=nexon.db

# ── Email (Gmail) ────────────────────────────────────────────
# How to get app password:
# 1. Go to myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Search "App Passwords" → create one named "NEXON"
# 4. Copy the 16-character password (spaces don't matter)
EMAIL_ADDRESS=
EMAIL_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# For Outlook/Office365:
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587

# ── SMS + WhatsApp (Twilio) ──────────────────────────────────
# Free trial at twilio.com — gives $15 credit, no credit card needed
# Get these from: console.twilio.com/us1/account/keys-credentials
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

# ── Slack ────────────────────────────────────────────────────
# Create bot at api.slack.com/apps → OAuth & Permissions → Bot Token
# Required scopes: chat:write, channels:read
SLACK_TOKEN=xoxb-

# ── File Paths ───────────────────────────────────────────────
# These are auto-created — no need to change
# NEXON_HOME=~/NEXON

# ── App Settings ─────────────────────────────────────────────
APP_HOST=127.0.0.1
APP_PORT=8000
