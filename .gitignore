# ============================================================
# NEXON .gitignore
# ============================================================

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.Python
pip-wheel-metadata/
share/python-wheels/
*.pyd

# Virtual environments
venv/
env/
.venv/
.env.local
ENV/
env.bak/
venv.bak/

# ── Environment & Secrets ─────────────────────────────────────
.env
.env.*
!.env.template
*.key
*.pem
secrets.json

# ── Database ──────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
nexon.db

# ── NEXON Data Directories ────────────────────────────────────
# These are generated at runtime in ~/NEXON/
# Don't commit user data
~/NEXON/

# Biometric face encodings (sensitive personal data)
frontend/renderer/biometric/
encodings.pkl
profiles.json

# ── Node.js / Electron ────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm
.yarn-integrity
.pnp
.pnp.js
lerna-debug.log*

# Electron build output
frontend/electron/dist/
frontend/electron/build/
out/
release/

# ── ML Models (large files — download on first run) ──────────
# Whisper models (~39MB–1.5GB)
*.pt
*.bin
~/.cache/whisper/

# sentence-transformers cache
~/.cache/huggingface/
~/.cache/torch/

# ── Logs ─────────────────────────────────────────────────────
*.log
logs/
*.log.*
npm-debug.log

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ── IDEs & Editors ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace

# ── Screenshots & Recordings (runtime generated) ─────────────
screenshots/
recordings/
*.png.bak

# ── Temp Files ────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.cache

# ── Test & Coverage ───────────────────────────────────────────
.coverage
.pytest_cache/
htmlcov/
.tox/
coverage.xml
*.cover
.hypothesis/

# ── Distribution / Packaging ──────────────────────────────────
*.dmg
*.exe
*.msi
*.AppImage
*.deb
*.rpm
MANIFEST

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints
*.ipynb

# ── Docker (if ever added) ────────────────────────────────────
.dockerignore
docker-compose.override.yml

# ── Keep these files ──────────────────────────────────────────
!.env.template
!requirements.txt
!package.json
!package-lock.json
!migrate_db.py
!setup_nexon.sh
!face_enrollment.html
!README.md