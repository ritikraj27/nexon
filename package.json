{
  "name": "nexon",
  "version": "1.0.0",
  "description": "NEXON - Agentic AI Operating System",
  "main": "frontend/electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.nexon.ai",
    "productName": "NEXON",
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    }
  },
  "dependencies": {
    "undici": "^8.0.2"
  }
}
